{
  "iching__1": "天行健，君子以自強不息。",
  "iching__1_1": "“潛龍，勿用”，陽在下也。",
  "iching__1_2": "“見龍再田”，德施普也。",
  "iching__1_3": "“終日乾乾”，反覆道也。",
  "iching__1_4": "“或躍在淵”，進無咎也。",
  "iching__1_5": "“飛龍在天”，“大人”造也。",
  "iching__1_6": "“亢龍有悔”，盈不可久也。",
  "iching__1_7": "“用九”，天德不可爲首也。",
  "iching__2": "地勢坤，君子以厚德載物。",
  "iching__2_1": "“履霜堅冰”，陰始凝也；馴致其道，至堅冰也。",
  "iching__2_2": "六二之動，“直”以“方”也。“不習無不利”，地道光也。",
  "iching__2_3": "“含章可貞”，以時發也；“或從王事”，知光大也。",
  "iching__2_4": "“括囊無咎”，慎不害也。",
  "iching__2_5": "“黃裳元吉”，文在中也。",
  "iching__2_6": "“龍戰於野”，其道窮也。",
  "iching__2_7": "用六“永貞”，以大終也。",
  "iching__3": "雲雷，屯。君子以經綸。",
  "iching__3_1": "雖磐桓，志行正也；以貴下賤，大得民也。",
  "iching__3_2": "六二之難，乘剛也。“十年乃字”，反常也。",
  "iching__3_3": "“即鹿無虞”，以從禽也。君子舍之；“往吝”，窮也。",
  "iching__3_4": "“求”而“往”，明也。",
  "iching__3_5": "“屯其膏”，施未光也。",
  "iching__3_6": "“泣血漣如”，何可長也？",
  "iching__4": "山下出泉，蒙。君子以果行育德。",
  "iching__4_1": "“利用刑人”，以正法也。",
  "iching__4_2": "“子克家”，剛柔接也。",
  "iching__4_3": "“勿用取女”，行不順也。",
  "iching__4_4": "“困蒙”之“吝”，獨遠實也。",
  "iching__4_5": "“童蒙”之“吉”，順以巽也。",
  "iching__4_6": "“利”用“禦寇”，上下順也。",
  "iching__5": "雲上於天，需。君子以飲食宴樂。",
  "iching__5_1": "“需於郊”，不犯難行也；“利用恆，無咎”，未失常也。",
  "iching__5_2": "“需於沙”，衍在中也；雖“小有言”，以“吉”“終”也。",
  "iching__5_3": "“需於泥”，災在外也；自我“致寇”，敬慎不敗也。",
  "iching__5_4": "“需於血”，順以聽也。",
  "iching__5_5": "“酒食，貞吉”，以中正也。",
  "iching__5_6": "“不速之客”來，“敬之，終吉”，雖不當位，未大失也。",
  "iching__6": "天與水違行，訟。君子以作事謀始。",
  "iching__6_1": "“不永所事”，訟不可長也；雖“有小言”，其辯明也。",
  "iching__6_2": "“不克訟”，歸逋，竄也；自下訟上，患至掇也。",
  "iching__6_3": "“食舊德”，從上吉也。",
  "iching__6_4": "“復即命，渝”，“安貞”不失也。",
  "iching__6_5": "“訟，元吉”，以中正也。",
  "iching__6_6": "以訟受服，亦不足敬也。",
  "iching__7": "地中有水，師。君子以容民畜衆。",
  "iching__7_1": "“師出以律”，失律“兇”也。",
  "iching__7_2": "“在師中吉”，承天寵也；“王三錫命”，懷萬邦也。",
  "iching__7_3": "“師或輿屍”，大無功也。",
  "iching__7_4": "“左次，無咎”，未失常也。",
  "iching__7_5": "“長子帥師”，以中行也；“弟子輿師”，使不當也。",
  "iching__7_6": "“大君有命”，以正功也；“小人勿用”，必亂邦也。",
  "iching__8": "地上有水，比。先王以建萬國，親諸侯。",
  "iching__8_1": "比之初六，有它吉也。",
  "iching__8_2": "“比之自內”，不自失也。",
  "iching__8_3": "“比之匪人”，不亦傷乎！",
  "iching__8_4": "“外比”於賢，以從上也。",
  "iching__8_5": "“顯比”之吉，位正中也。舍逆取順，“失前禽”也。“邑人不誡”，上使中也。",
  "iching__8_6": "“比之無首”，無所終也。",
  "iching__9": "風行天上，小畜。君子以懿文德。",
  "iching__9_1": "“復自道”，其義“吉”也。",
  "iching__9_2": "“牽復”在中，亦不自失也。",
  "iching__9_3": "“夫妻反目”，不能正室也。",
  "iching__9_4": "“有孚”“惕出”，上合志也。",
  "iching__9_5": "“有孚攣如”，不獨富也。",
  "iching__9_6": "“既雨既處”，“德”積“載”也。“君子徵兇”，有所疑也。",
  "iching__10": "上天下澤，履。君子以辨上下，定民志。",
  "iching__10_1": "“素履”之“往”，獨行願也。",
  "iching__10_2": "“幽人貞吉”，中不自亂也。",
  "iching__10_3": "“眇能視”，不足以有明也；“跛能履”，不足以與行也；“咥人之兇”，位不當也；“武人爲於大君”，志剛也。",
  "iching__10_4": "“愬愬，終吉”，志行也。",
  "iching__10_5": "“夬履，貞厲”，位正當也。",
  "iching__10_6": "元吉在上，大有慶也。",
  "iching__11": "天地交，泰。後以財成天地之道，輔相天地之宜，以左右民。",
  "iching__11_1": "“拔茅”“徵吉”，志在外也。",
  "iching__11_2": "“包荒”，“得尚於中行”，以光大也。",
  "iching__11_3": "“無往不復”，天地際也。",
  "iching__11_4": "“翩翩，不富”，皆失實也。“不戒以孚”，中心願也。",
  "iching__11_5": "“以祉元吉”，中以行願也。",
  "iching__11_6": "“城復於隍”，其命亂也。",
  "iching__12": "天地不交，否。君子以儉德闢難，不可榮以祿。",
  "iching__12_1": "“拔茅”“貞吉”，志在君也。",
  "iching__12_2": "“大人否，亨”，不亂羣也。",
  "iching__12_3": "“包羞”，位不當也。",
  "iching__12_4": "“有命無咎”，志行也。",
  "iching__12_5": "“大人”之“吉”，位正當也。",
  "iching__12_6": "否終則傾，何可長也？",
  "iching__13": "天與火，同人。君子以類族辨物。",
  "iching__13_1": "出門同人，又誰“咎”也。",
  "iching__13_2": "“同人於宗”，吝道也。",
  "iching__13_3": "“伏戎於莽”，敵剛也；“三歲不興”，安行也？",
  "iching__13_4": "“乘其墉”，義弗克也；其吉，則困而反則也。",
  "iching__13_5": "“同人”之先，以中直也。大師相遇，言相剋也。",
  "iching__13_6": "“同人於郊”，志未得也。",
  "iching__14": "火在天上，大有。君子以遏惡揚善，順天休命。",
  "iching__14_1": "大有初九，“無交害”也。",
  "iching__14_2": "“大車以載”，積中不敗也。",
  "iching__14_3": "“公用亨於天子”，小人害也。",
  "iching__14_4": "“匪其彭，無咎”，明辨晢也。",
  "iching__14_5": "“厥孚交如”，信以發志也；“威如”之吉，易而無備也。",
  "iching__14_6": "大有上吉，“自天祐”也。",
  "iching__15": "地中有山，謙。君子以裒多益寡，稱物平施。",
  "iching__15_1": "“謙謙君子”，卑以自牧也。",
  "iching__15_2": "“鳴謙，貞吉”，中心得也。",
  "iching__15_3": "“勞謙君子”，萬民服也。",
  "iching__15_4": "“無不利，撝謙”，不違則也。",
  "iching__15_5": "“利用侵伐”，徵不服也。",
  "iching__15_6": "“鳴謙”，志未得也；可“用行師”，“徵邑國”也。",
  "iching__16": "雷出地奮，豫；先王以作樂崇德，殷薦之上帝，以配祖考。",
  "iching__16_1": "初六“鳴豫”，志窮“兇”也。",
  "iching__16_2": "“不終日，貞吉”，以中正也。",
  "iching__16_3": "“盱豫”“有悔”，位不當也。",
  "iching__16_4": "“由豫，大有得”，志大行也。",
  "iching__16_5": "六五“貞疾”，乘剛也；“恆不死”，中未亡也。",
  "iching__16_6": "“冥豫”在上，何可長也？",
  "iching__17": "澤中有雷，隨。君子以嚮晦入宴息。",
  "iching__17_1": "“官有渝”，從正“吉”也；“出門交有功”，不失也。",
  "iching__17_2": "“系小子”，弗兼與也。",
  "iching__17_3": "“系丈夫”，志舍下也。",
  "iching__17_4": "“隨有獲”，其義“兇”也；“有孚在道”，明功也。",
  "iching__17_5": "“孚於嘉，吉”，位正中也。",
  "iching__17_6": "“拘繫之”，上窮也。",
  "iching__18": "山下有風，蠱。君子以振民育德。",
  "iching__18_1": "“幹父之蠱”，意承考也。",
  "iching__18_2": "“幹母之蠱”，得中道也。",
  "iching__18_3": "“幹父之蠱”，終“無咎”也。",
  "iching__18_4": "“裕父之蠱”，往未得也。",
  "iching__18_5": "“幹父”“用譽”，承以德也。",
  "iching__18_6": "“不事王侯”，志可則也。",
  "iching__19": "澤上有地，臨。君子以教思無窮，容保民無疆。",
  "iching__19_1": "“鹹臨，貞吉”，志行正也。",
  "iching__19_2": "“鹹臨，吉，無不利”，未順命也。",
  "iching__19_3": "“甘臨”，位不當也；“既憂之”，“咎”不長也。",
  "iching__19_4": "“至臨，無咎”，位當也。",
  "iching__19_5": "“大君之宜”，行中之謂也。",
  "iching__19_6": "“敦臨”之“吉”，志在內也。",
  "iching__20": "風行地上，觀。先王以省方觀民設教。",
  "iching__20_1": "初六“童觀”，小人道也。",
  "iching__20_2": "“窺觀”“女貞”，亦可醜也。",
  "iching__20_3": "“觀我生，進退”，未失道也。",
  "iching__20_4": "“觀國之光”，尚“賓”也。",
  "iching__20_5": "“觀我生”，觀民也。",
  "iching__20_6": "“觀其生”，志未平也。",
  "iching__21": "雷電，噬嗑。先王以明罰敕法。",
  "iching__21_1": "“屨校滅趾”，不行也。",
  "iching__21_2": "“噬膚滅鼻”，乘剛也。",
  "iching__21_3": "“遇毒”，位不當也。",
  "iching__21_4": "“利艱貞吉”，未光也。",
  "iching__21_5": "“貞厲無咎”，得當也。",
  "iching__21_6": "“何校滅耳”，聰不明也。",
  "iching__22": "山下有火，賁。君子以明庶政，無敢折獄。",
  "iching__22_1": "“舍車而徒”，義弗乘也。",
  "iching__22_2": "“賁其須”，與上興也。",
  "iching__22_3": "“永貞”之“吉”，終莫之陵也。",
  "iching__22_4": "六四，當位疑也；“匪寇，婚媾”，終無尤也。",
  "iching__22_5": "六五之吉，有喜也。",
  "iching__22_6": "白賁，無咎，上得志也。",
  "iching__23": "山附於地，剝。上以厚下安宅。",
  "iching__23_1": "“剝牀以足”，以滅下也。",
  "iching__23_2": "“剝牀以辨”，未有與也。",
  "iching__23_3": "“剝之，無咎”，失上下也。",
  "iching__23_4": "“剝牀以膚”，切近災也。",
  "iching__23_5": "“以宮人寵”，終無尤也。",
  "iching__23_6": "“君子得輿”，民所載也；“小人剝廬”，終不可用也。",
  "iching__24": "雷在地中，復。先王以至日閉關，商旅不行，後不省方。",
  "iching__24_1": "“不遠”之“復”，以修身也。",
  "iching__24_2": "“休復”之“吉”，以下仁也。",
  "iching__24_3": "“頻復”之“厲”，義“無咎”也。",
  "iching__24_4": "“中行獨復”，以從道也。",
  "iching__24_5": "“敦復，無悔”，中以自考也。",
  "iching__24_6": "“迷復”之“兇”，反君道也。",
  "iching__25": "天下雷行，物與無妄。先王以茂對時，育萬物。",
  "iching__25_1": "“無妄”之“往”，得志也。",
  "iching__25_2": "“不耕穫”，未富也。",
  "iching__25_3": "“行人”得牛，“邑人”災也。",
  "iching__25_4": "“可貞，無咎”，固有之也。",
  "iching__25_5": "“無妄”之“藥”，不可試也。",
  "iching__25_6": "“無妄”之“行”，窮之災也。",
  "iching__26": "天在山中，大畜。君子以多識前言往行，以畜其德。",
  "iching__26_1": "“有厲，利已”，不犯災也。",
  "iching__26_2": "“輿說輹”，中無尤也。",
  "iching__26_3": "“利有攸往”，上合志也。",
  "iching__26_4": "六四“元吉”，有喜也。",
  "iching__26_5": "六五之“吉”，有慶也。",
  "iching__26_6": "“何天之衢”，道大行也。",
  "iching__27": "山下有雷，頤。君子以慎言語，節飲食。",
  "iching__27_1": "“觀我朵頤”，亦不足貴也。",
  "iching__27_2": "六二“徵兇”，行失類也。",
  "iching__27_3": "“十年勿用”，道大悖也。",
  "iching__27_4": "“顛頤”之“吉”，上施光也。",
  "iching__27_5": "“居貞”之“吉”，順以從上也。",
  "iching__27_6": "“由頤，厲吉”，大有慶也。",
  "iching__28": "澤滅木，大過；君子以獨立不懼，遁世無悶。",
  "iching__28_1": "“藉用白茅”，柔在下也。",
  "iching__28_2": "“老夫”“女妻”，過以相與也。",
  "iching__28_3": "“棟橈”之“兇”，不可以有輔也。",
  "iching__28_4": "“棟隆”之“吉”，不橈乎下也。",
  "iching__28_5": "“枯楊生華”，何可久也？“老婦”“士夫”，亦可醜也。",
  "iching__28_6": "“過涉”之“兇”，不可咎也。",
  "iching__29": "水洊至，習坎。君子以常德行，習教事。",
  "iching__29_1": "“習坎”入坎，失道兇也。",
  "iching__29_2": "“求小得”，未出中也。",
  "iching__29_3": "“來之坎坎”，終無功也。",
  "iching__29_4": "“樽酒，簋貳”，剛柔際也。",
  "iching__29_5": "“坎不盈”，中未大也。",
  "iching__29_6": "上六失道，兇“三歲”也。",
  "iching__30": "明兩作，離。大人以繼明照於四方。",
  "iching__30_1": "“履錯”之“敬”，以闢咎也。",
  "iching__30_2": "“黃離，元吉”，得中道也。",
  "iching__30_3": "“日昃之離”，何可久也！",
  "iching__30_4": "“突如其來如”，無所容也。",
  "iching__30_5": "六五之“吉”，離王公也。",
  "iching__30_6": "“王用出徵”，以正邦也。",
  "iching__31": "山上有澤，鹹。君子以虛受人。",
  "iching__31_1": "“鹹其拇”，志在外也。",
  "iching__31_2": "雖“兇”“居吉”，順不害也。",
  "iching__31_3": "“鹹其股”，亦不處也。志在隨人，所執下也。",
  "iching__31_4": "“貞吉，悔亡”，未感害也；“憧憧往來”，未光大也。",
  "iching__31_5": "“鹹其脢”，志未也。",
  "iching__31_6": "“鹹其輔頰舌”，滕口說也。",
  "iching__32": "雷風，恆。君子以立不易方。",
  "iching__32_1": "“浚恆”之“兇”，始求深也。",
  "iching__32_2": "九二“悔亡”，能久中也。",
  "iching__32_3": "“不恆其德”，無所容也。",
  "iching__32_4": "久非其位，安得禽也？",
  "iching__32_5": "“婦人”貞吉，從一而終也。“夫子”制義，從婦兇也。",
  "iching__32_6": "“振恆”在上，大無功也。",
  "iching__33": "天下有山，遁。君子以遠小人，不惡而嚴。",
  "iching__33_1": "“遁尾”之“厲”，不往，何災也？",
  "iching__33_2": "“執用黃牛”，固志也。",
  "iching__33_3": "“系遁之厲”，有疾憊也；“畜臣妾，吉”，不可大事也。",
  "iching__33_4": "“君子”“好遁”，“小人否”也。",
  "iching__33_5": "“嘉遁，貞吉”，以正志也。",
  "iching__33_6": "“肥遁，無不利”，無所疑也。",
  "iching__34": "雷在天上，大壯。君子以非禮弗履。",
  "iching__34_1": "“壯於趾”，其孚窮也。",
  "iching__34_2": "九二“貞吉”，以中也。",
  "iching__34_3": "“小人用壯”，“君子”“罔”也。",
  "iching__34_4": "“藩決不羸”，尚往也。",
  "iching__34_5": "“喪羊於易”，位不當也。",
  "iching__34_6": "“不能退，不能遂”，不詳也；“艱則吉”，咎不長也。",
  "iching__35": "明出地上，晉。君子以自昭明德。",
  "iching__35_1": "“晉中摧如”，獨行正也。“裕無咎”，未受命也。",
  "iching__35_2": "“受茲介福”，以中正也。",
  "iching__35_3": "“衆允”之志，上行也。",
  "iching__35_4": "“鼫鼠”“貞厲”，位不當也。",
  "iching__35_5": "“失得勿恤”，往有慶也。",
  "iching__35_6": "“維用伐邑”，道未光也。",
  "iching__36": "明入地中，明夷。君子以蒞衆，用晦而明。",
  "iching__36_1": "“君子於行”，義不食也。",
  "iching__36_2": "六二之“吉”，順以則也。",
  "iching__36_3": "“南狩”之志，乃大得也。",
  "iching__36_4": "“入於左腹”，獲心意也。",
  "iching__36_5": "“箕子”之“貞”，明不可息也。",
  "iching__36_6": "“初登於天”，照四國也。“後入於地”，失則也。",
  "iching__37": "風自火出，家人。君子以言有物而行有恆。",
  "iching__37_1": "“閒有家”，志未變也。",
  "iching__37_2": "六二之“吉”，順以巽也。",
  "iching__37_3": "“家人嗃嗃”，未失也；“婦子嘻嘻”，失家節也。",
  "iching__37_4": "“富家，大吉”，順在位也。",
  "iching__37_5": "“王假有家”，交相愛也。",
  "iching__37_6": "“威如”之“吉”，反身之謂也。",
  "iching__38": "上火下澤，睽；君子以同而異。",
  "iching__38_1": "“見惡人”，以闢咎也。",
  "iching__38_2": "“遇主於巷”，未失道也。",
  "iching__38_3": "“見輿曳”，位不當也。“無初有終”，遇剛也。",
  "iching__38_4": "“交孚”“無咎”，志行也。",
  "iching__38_5": "“厥宗噬膚”，往有慶也。",
  "iching__38_6": "“遇雨”之“吉”，羣疑亡也。",
  "iching__39": "山上有水，蹇。君子以反身修德。",
  "iching__39_1": "“往蹇，來譽”，宜待也。",
  "iching__39_2": "“王臣蹇蹇”，終無尤也。",
  "iching__39_3": "“往蹇，來反”，內喜之也。",
  "iching__39_4": "“往蹇，來連”，當位實也。",
  "iching__39_5": "“大蹇，朋來”，以中節也。",
  "iching__39_6": "“往蹇，來碩”，志在內也；“利見大人”，以從貴也。",
  "iching__40": "雷雨作，解。君子以赦過宥罪。",
  "iching__40_1": "剛柔之際，義“無咎”也。",
  "iching__40_2": "九二“貞吉”，得中道也。",
  "iching__40_3": "“負且乘”，亦可醜也；自我致戎，又誰咎也？",
  "iching__40_4": "“解而拇”，未當位也。",
  "iching__40_5": "“君子”“有解”，小人退也。",
  "iching__40_6": "“公用射隼”，以解悖也。",
  "iching__41": "山下有澤，損。君子以懲忿窒慾。",
  "iching__41_1": "“已事遄往”，尚合志也。",
  "iching__41_2": "九二“利貞”，中以爲志也。",
  "iching__41_3": "“一人行”，三則疑也。",
  "iching__41_4": "“損其疾”，亦可喜也。",
  "iching__41_5": "六五“元吉”，自上祐也。",
  "iching__41_6": "“弗損益之”，大得志也。",
  "iching__42": "風雷，益。君子以見善則遷，有過則改。",
  "iching__42_1": "“元吉，無咎”，下不厚事也。",
  "iching__42_2": "“或益之”，自外來也。",
  "iching__42_3": "益“用凶事”，固有之也。",
  "iching__42_4": "“告公從”，以益志也。",
  "iching__42_5": "“有孚惠心”，“勿問”之矣；“惠我德”，大得志也。",
  "iching__42_6": "“莫益之”，偏辭也；“或擊之”，自外來也。",
  "iching__43": "澤上於天，夬。君子以施祿及下，居德則忌。",
  "iching__43_1": "“不勝”而“往”，咎也。",
  "iching__43_2": "“有戎”“勿恤”，得中道也。",
  "iching__43_3": "“君子夬夬”，終無咎也。",
  "iching__43_4": "“其行次且”，位不當也；“聞言不信”，聰不明也。",
  "iching__43_5": "“中行無咎”，中未光也。",
  "iching__43_6": "“無號”之“兇”，終不可長也。",
  "iching__44": "天下有風，姤。後以施命誥四方。",
  "iching__44_1": "“繫於金柅”，柔道牽也。",
  "iching__44_2": "“包有魚”，義不及賓也。",
  "iching__44_3": "“其行次且”，行未牽也。",
  "iching__44_4": "“無魚”之“兇”，遠民也。",
  "iching__44_5": "九五“含章”，中正也；“有隕自天”，志不捨命也。",
  "iching__44_6": "“姤其角”，上窮吝也。",
  "iching__45": "澤上於地，萃。君子以除戎器，戒不虞。",
  "iching__45_1": "“乃亂乃萃”，其志亂也。",
  "iching__45_2": "“引吉，無咎”，中未變也。",
  "iching__45_3": "“往無咎”，上巽也。",
  "iching__45_4": "“大吉，無咎”，位不當也。",
  "iching__45_5": "“萃有位”，志未光也。",
  "iching__45_6": "“齎諮涕洟”，未安上也。",
  "iching__46": "地中生木，升。君子以順德，積小以高大。",
  "iching__46_1": "“允升，大吉”，上合志也。",
  "iching__46_2": "九二之“孚”，有喜也。",
  "iching__46_3": "“升虛邑”，無所疑也。",
  "iching__46_4": "“王用亨於岐山”，順事也。",
  "iching__46_5": "“貞吉，升階”，大得志也。",
  "iching__46_6": "“冥升在上”，消不富也。",
  "iching__47": "澤無水，困。君子以致命遂志。",
  "iching__47_1": "“入於幽谷”，幽不明也。",
  "iching__47_2": "“困於酒食”，中有慶也。",
  "iching__47_3": "“據於蒺藜”，乘剛也；“入於其宮，不見其妻”，不祥也。",
  "iching__47_4": "“來徐徐”，志在下也；雖不當位，有與也。",
  "iching__47_5": "“劓刖”，志未得也。“乃徐有說”，以中直也。“利用祭祀”，受福也。",
  "iching__47_6": "“困於葛藟”，未當也；“動悔，有悔”，吉行也。",
  "iching__48": "木上有水，井。君子以勞民勸相。",
  "iching__48_1": "“井泥不食”，下也；“舊井無禽”，時舍也。",
  "iching__48_2": "“井谷射鮒”，無與也。",
  "iching__48_3": "“井渫不食”，行惻也；求“王明”，受福也。",
  "iching__48_4": "“井甃，無咎”，修井也。",
  "iching__48_5": "“寒泉”之“食”，中正也。",
  "iching__48_6": "“元吉”在上，大成也。",
  "iching__49": "澤中有火，革。君子以治歷明時。",
  "iching__49_1": "“鞏用黃牛”，不可以有爲也。",
  "iching__49_2": "“巳日”“革之”，行有嘉也。",
  "iching__49_3": "“革言三就”，又何之矣！",
  "iching__49_4": "“改命”之“吉”，信志也。",
  "iching__49_5": "“大人虎變”，其文炳也。",
  "iching__49_6": "“君子豹變”，其文蔚也；“小人革面”，順以從君也。",
  "iching__50": "木上有火，鼎。君子以正位凝命。",
  "iching__50_1": "“鼎顛趾”，未悖也；“利出否”，以從貴也。",
  "iching__50_2": "“鼎有實”，慎所之也；“我仇有疾”，終無尤也。",
  "iching__50_3": "“鼎耳革”，失其義也。",
  "iching__50_4": "“覆公餗”，信如何也。",
  "iching__50_5": "“鼎黃耳”，中以爲實也。",
  "iching__50_6": "“玉鉉”在上，剛柔節也。",
  "iching__51": "洊雷，震。君子以恐懼修省。",
  "iching__51_1": "“震來虩虩”，恐致福也；“笑言啞啞”，後有則也。",
  "iching__51_2": "“震來厲”，乘剛也。",
  "iching__51_3": "“震蘇蘇”，位不當也。",
  "iching__51_4": "“震遂泥”，未光也。",
  "iching__51_5": "“震往來，厲”，危行也；其事在中，大無喪也。",
  "iching__51_6": "“震索索”，中未得也；雖“兇”“無咎”，畏鄰戒也。",
  "iching__52": "兼山，艮。君子以思不出其位。",
  "iching__52_1": "“艮其趾”，未失正也。",
  "iching__52_2": "“不拯其隨”，未退聽也。",
  "iching__52_3": "“艮其限”，危“燻心”也。",
  "iching__52_4": "“艮其身”，止諸躬也。",
  "iching__52_5": "“艮其輔”，以中正也。",
  "iching__52_6": "“敦艮”之“吉”，以厚終也。",
  "iching__53": "山上有木，漸。君子以居賢德善俗。",
  "iching__53_1": "“小子”之“厲”，義無咎也。",
  "iching__53_2": "“飲食衎衎”，不素飽也。",
  "iching__53_3": "“夫徵不復”，離羣醜也；“婦孕不育”，失其道也；“利”用“禦寇”，順相保也。",
  "iching__53_4": "“或得其桷”，順以巽也。",
  "iching__53_5": "“終莫之勝，吉”，得所願也。",
  "iching__53_6": "“其羽可用爲儀，吉”，不可亂也。",
  "iching__54": "澤上有雷，歸妹。君子以永終知敝。",
  "iching__54_1": "“歸妹以娣”，以恆也；“跛能履”“吉”，相承也。",
  "iching__54_2": "“利幽人之貞”，未變常也。",
  "iching__54_3": "“歸妹以須”，未當也。",
  "iching__54_4": "“愆期”之志，有待而行也。",
  "iching__54_5": "“帝乙歸妹”，“不如其娣之袂良”也，其位在中，以貴行也。",
  "iching__54_6": "上六“無實”，“承”虛“筐”也。",
  "iching__55": "雷電皆至，豐。君子以折獄致刑。",
  "iching__55_1": "“雖旬無咎”，過旬災也。",
  "iching__55_2": "“有孚發若”，信以發志也。",
  "iching__55_3": "“豐其沛”，不可大事也；“折其右肱”，終不可用也。",
  "iching__55_4": "“豐其蔀”，位不當也；“日中見鬥”，幽不明也；“遇其夷主，吉”，行也。",
  "iching__55_5": "六五之“吉”，“有慶”也。",
  "iching__55_6": "“豐其屋”，天際翔也；“窺其戶，闃其無人”，自藏也。",
  "iching__56": "山上有火，旅。君子以明慎用刑而不留獄。",
  "iching__56_1": "“旅瑣瑣”，志窮災也。",
  "iching__56_2": "“得童僕，貞”，終無尤也。",
  "iching__56_3": "“旅焚其次”，亦以傷矣；以旅與下，其義“喪”也。",
  "iching__56_4": "“旅於處”，未得位也；“得其資斧”，心未快也。",
  "iching__56_5": "“終以譽命”，上逮也。",
  "iching__56_6": "以旅在上，其義“焚”也；“喪牛於易”，終莫之聞也。",
  "iching__57": "隨風，巽。君子以申命行事。",
  "iching__57_1": "“進退”，志疑也；“利武人之貞”，志治也。",
  "iching__57_2": "“紛若”之“吉”，得中也。",
  "iching__57_3": "“頻巽”之“吝”，志窮也。",
  "iching__57_4": "“田獲三品”，有功也。",
  "iching__57_5": "九五之“吉”，位正中也。",
  "iching__57_6": "“巽在牀下”，上窮也；“喪其資斧”，正乎“兇”也。",
  "iching__58": "麗澤，兌。君子以朋友講習。",
  "iching__58_1": "“和兌”之“吉”，行未疑也。",
  "iching__58_2": "“孚兌”之“吉”，信志也。",
  "iching__58_3": "“來兌”之“兇”，位不當也。",
  "iching__58_4": "九四之“喜”，有慶也。",
  "iching__58_5": "“孚於剝”，位正當也。",
  "iching__58_6": "上六“引兌”，未光也。",
  "iching__59": "風行水上，渙。先王以享於帝，立廟。",
  "iching__59_1": "初六之“吉”，順也。",
  "iching__59_2": "“渙奔其機”，得願也。",
  "iching__59_3": "“渙其躬”，志在外也。",
  "iching__59_4": "“渙其羣，元吉”，光大也。",
  "iching__59_5": "“王居”“無咎”，正位也。",
  "iching__59_6": "“渙其血”，遠害也。",
  "iching__60": "澤上有水，節。君子以制數度，議德行。",
  "iching__60_1": "“不出戶庭”，知通塞也。",
  "iching__60_2": "“不出門庭，兇”，失時極也。",
  "iching__60_3": "“不節”之“嗟”，又誰“咎”也？",
  "iching__60_4": "“安節”之“亨”，承上道也。",
  "iching__60_5": "“甘節”之“吉”，居位中也。",
  "iching__60_6": "“苦節，貞兇”，其道窮也。",
  "iching__61": "澤上有風，中孚。君子以議獄緩死。",
  "iching__61_1": "初九“虞吉”，志未變也。",
  "iching__61_2": "“其子和之”，中心願也。",
  "iching__61_3": "“或鼓或罷”，位不當也。",
  "iching__61_4": "“馬匹亡”，絕類上也。",
  "iching__61_5": "“有孚攣如”，位正當也。",
  "iching__61_6": "“翰音登於天”，何可長也！",
  "iching__62": "山上有雷，小過。君子以行過乎恭，喪過乎哀，用過乎儉。",
  "iching__62_1": "“飛鳥以兇”，不可如何也。",
  "iching__62_2": "“不及其君”，臣不可過也。",
  "iching__62_3": "“從或戕之”，兇如何也。",
  "iching__62_4": "“弗過遇之”，位不當也；“往厲必戒”，終不可長也。",
  "iching__62_5": "“密雲不雨”，已上也。",
  "iching__62_6": "“弗遇過之”，已亢也。",
  "iching__63": "水在火上，既濟。君子以思患而豫防之。",
  "iching__63_1": "“曳其輪”，義無咎也。",
  "iching__63_2": "“七日得”，以中道也。",
  "iching__63_3": "“三年克之”，憊也。",
  "iching__63_4": "終日戒，有所疑也。",
  "iching__63_5": "“東鄰殺牛，不如西鄰”之時也；“實受其福”，吉大來也。",
  "iching__63_6": "“濡其首，厲”，何可久也！",
  "iching__64": "火在水上，未濟。君子以慎辨物居方。",
  "iching__64_1": "“濡其尾”，亦不知極也。",
  "iching__64_2": "九二“貞吉”，中以行正也。",
  "iching__64_3": "“未濟，徵兇”，位不當也。",
  "iching__64_4": "“貞吉，悔亡”，志行也。",
  "iching__64_5": "“君子之光”，其暉“吉”也。",
  "iching__64_6": "“飲酒”濡首，亦不知節也。"
}