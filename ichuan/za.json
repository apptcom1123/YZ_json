{
  "#1": "《乾》剛。《坤》柔。",
  "#3": "《屯》見而不失其居。《蒙》雜而著。",
  "#5": "《需》，不進也。《訟》，不親也。",
  "#7": "《比》樂。《師》憂。",
  "#9": "《小畜》，寡也。《履》，不處也。",
  "#11": "《否》《泰》，反其類也。",
  "#13": "《大有》，眾也。《同人》，親也。",
  "#15": "《謙》輕而《豫》怠也。",
  "#17": "《隨》，無故也。《蠱》則飭也。",
  "#19": "《臨》《觀》之義，或與或求。",
  "#21": "《噬嗑》，食也。《賁》，無色也。",
  "#23": "《剝》，爛也。《復》，反也。",
  "#25": "《大畜》，時也。《無妄》，災也。",
  "#27": "《頤》，養正也。《大過》，顛也。",
  "#29": "《離》上而《坎》下也。",
  "#31": "《咸》，速也。《恆》，久也。",
  "#33": "《大壯》則止。《遯》則退也。",
  "#35": "《晉》，晝也。《明夷》，誅也。",
  "#37": "《睽》，外也。《家人》，內也。",
  "#39": "《解》，緩也。《蹇》，難也。",
  "#41": "《損》《益》，盛衰之始也。",
  "#43": "《夬》，決也，剛決柔也。《姤》，遇也，柔遇剛也。",
  "#45": "《萃》聚而《升》不來也。",
  "#47": "《井》通而《困》相遇也。",
  "#49": "《革》，去故也。《鼎》，取新也。",
  "#51": "《震》，起也。《艮》，止也。",
  "#53": "《漸》，女歸待男行也。《歸妹》，女之終也。",
  "#55": "《豐》，多故也。親寡，旅也。",
  "#57": "《兌》見而《巽》伏也。",
  "#59": "《渙》，離也。《節》，止也。",
  "#61": "《小過》，過也。《中孚》，信也。",
  "#63": "《既濟》，定也。《未濟》，男之窮也。"
}
